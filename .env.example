# Environment Variables Template

APP_ENV=development
APP_PORT=5500
API_BASE_URL=http://localhost:3000
LOG_LEVEL=info
DB_CLIENT=mssql
APP_CORS_ORIGIN=http://localhost:5500
SESSION_COOKIE_NAME=hsm_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_TTL_HOURS=168

# SQL Server Express (backend migration target)
MSSQL_SERVER=localhost\SQLEXPRESS
# Optional port; leave blank for named-instance discovery
MSSQL_PORT=
MSSQL_DATABASE=HomeSchoolManagement
MSSQL_USER=sa
MSSQL_PASSWORD=CHANGEME
MSSQL_ENCRYPT=false
MSSQL_TRUST_SERVER_CERTIFICATE=true

# PostgreSQL (hosted runtime target)
PGHOST=192.168.1.202
PGPORT=5432
PGDATABASE=appdb
PGUSER=appuser
PGPASSWORD=CHANGEME
PGSSLMODE=disable
CONTROL_PLANE_BASE_URL=http://127.0.0.1:3100
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGEME

# Public SaaS / Stripe (control-api commercial checkout)
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGEME
STRIPE_SECRET_KEY=sk_test_CHANGEME
STRIPE_WEBHOOK_SECRET=whsec_CHANGEME
PUBLIC_APP_BASE_URL=https://navigrader.com
PUBLIC_SIGNUP_STATUS_BASE_URL=https://navigrader.com
PUBLIC_CHECKOUT_SUCCESS_URL=https://navigrader.com/signup-status.html?checkout=success
PUBLIC_CHECKOUT_CANCEL_URL=https://navigrader.com/signup-status.html?checkout=cancel
PUBLIC_DEFAULT_DOMAIN_SUFFIX=navigrader.com

# Hosted/commercial outbound mail (control-api)
CONTROL_MAIL_PROVIDER=postmark
CONTROL_MAIL_MODE=allowlist_only
CONTROL_MAIL_ALLOWLIST=support@navigrader.com
CONTROL_MAIL_FROM_NAME=Navigrader Support
CONTROL_MAIL_FROM_EMAIL=support@navigrader.com
CONTROL_MAIL_REPLY_TO_EMAIL=support@navigrader.com
CONTROL_MAIL_SUPPORT_EMAIL=support@navigrader.com
CONTROL_MAIL_ENVIRONMENT_LABEL=Production
CONTROL_MAIL_POSTMARK_SERVER_NAME=navigrader-email
CONTROL_MAIL_POSTMARK_SERVER_TOKEN=pm_CHANGEME
CONTROL_MAIL_POSTMARK_MESSAGE_STREAM=
CONTROL_MAIL_REQUEST_TIMEOUT_MS=10000
