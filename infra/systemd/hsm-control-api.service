[Unit]
Description=Home School Management Control API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=debian
Group=debian
WorkingDirectory=/home/debian/apps/home-school-management/control-api
Environment=CONTROL_APP_ENV=production
Environment=CONTROL_APP_PORT=3100
Environment=CONTROL_APP_CORS_ORIGIN=http://192.168.1.210
Environment=CONTROL_SESSION_COOKIE_NAME=hsm_operator_session
Environment=CONTROL_SESSION_COOKIE_SECURE=false
Environment=CONTROL_SESSION_COOKIE_SAMESITE=Lax
Environment=CONTROL_SESSION_TTL_HOURS=12
Environment=CONTROL_INTERNAL_API_KEY=HSM_CONTROL_PLANE_SYNC_KEY
Environment=CONTROL_INTERNAL_AUTH_SECRET=HSM_CTRL_SVC_20260329_Ff2nq4V7xB9mLc3pRe6sTu8wYz1Ka5Qh
Environment=CONTROL_INTERNAL_AUTH_ISSUER=control-plane
Environment=CONTROL_INTERNAL_TENANT_RUNTIME_AUDIENCE=tenant-runtime-internal
Environment=CONTROL_INTERNAL_RUNTIME_RESOLVE_AUDIENCE=control-plane-internal
Environment=CONTROL_INTERNAL_AUTH_TTL_SECONDS=120
Environment=CONTROL_INTERNAL_AUTH_CLOCK_SKEW_SECONDS=30
Environment=CONTROL_INTERNAL_ALLOW_LEGACY_API_KEY=false
Environment=CONTROL_PGHOST=192.168.1.202
Environment=CONTROL_PGPORT=5432
Environment=CONTROL_PGDATABASE=appdb
Environment=CONTROL_PGUSER=appuser
Environment=CONTROL_PGPASSWORD=StrongPassword123!
Environment="PGOPTIONS=-c search_path=hsm_control_staging"
Environment=CONTROL_DEPLOYMENT_ENABLED=true
Environment=CONTROL_DEPLOY_LOCAL_HOSTS=APP001,192.168.1.200,127.0.0.1,localhost
Environment=CONTROL_HOST_ALIASES=APP001=192.168.1.200,WEB001=192.168.1.210,DB001=192.168.1.202
Environment=PUBLIC_DEFAULT_DOMAIN_SUFFIX=school.local
Environment=CONTROL_COMMERCIAL_DEFAULT_APP_HOST=APP001
Environment=CONTROL_COMMERCIAL_DEFAULT_WEB_HOST=WEB001
Environment=CONTROL_COMMERCIAL_DEFAULT_DATABASE_HOST=192.168.1.202
Environment=CONTROL_COMMERCIAL_DEFAULT_DATABASE_NAME=appdb
ExecStart=/usr/bin/node src/app.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
